# =============================================================================
# Flask backend (legacy) — server bind / debug / CORS
# =============================================================================
# Defaults are SAFE: loopback only, debug off, CORS limited to localhost.
# Override only when you understand the implications.

# FLASK_HOST=127.0.0.1
# FLASK_PORT=5040

# Set to "true" only on a host you fully control. NEVER combine FLASK_DEBUG=true
# with a non-loopback FLASK_HOST: the Werkzeug debugger is remote-code-execution.
# FLASK_DEBUG=false

# Comma-separated list of origins allowed to call the API from a browser.
# Use "*" only if you really mean "any origin" (anonymous read/write across
# tabs); otherwise list each origin explicitly.
# CORS_ALLOWED_ORIGINS=http://localhost:5040,http://127.0.0.1:5040

# SSL context for the built-in Flask dev server.
# Set to "adhoc" (requires pyopenssl) for local development when you need HTTPS
# (e.g. browser microphone access). Leave unset (or commented out) in production —
# use a proper reverse proxy (Nginx / Caddy) with a real certificate instead.
# FLASK_SSL_CONTEXT=adhoc

# Disable SSL verification for internal audio_grabber requests when using 
# self-signed certificates or 'adhoc' context above. Set to 'False' locally.
# FLASK_SSL_VERIFY=True

# How long a per-source ?source=<name> session pointer stays valid without a
# refresh, in seconds. Default 7200 (2 hours).
# SESSION_TTL_SECONDS=7200

# =============================================================================
# Whisper / faster-whisper Model Configuration
# =============================================================================
# The transcription backend now uses faster-whisper (CTranslate2 engine).
# Models are automatically downloaded from HuggingFace Hub and cached at
# ~/.cache/huggingface/hub on first use.
#
# Default model: medium (good balance of speed and accuracy with INT8 quantization)
# Available sizes: tiny, base, small, medium, large-v2, large-v3
# WHISPER_MODEL_SIZE=medium

# Hardware Selection (optional, defaults to cuda if available, else cpu)
# WHISPER_DEVICE=cpu

# Set to "true" to delegate transcription to a whisper.cpp HTTP server
# instead of the in-process faster-whisper provider.
# WHISPER_SERVER_USE=false

# Base URL of the whisper.cpp server. The server appends /inference itself.
# WHISPER_SERVER=http://localhost:8007

# =============================================================================
# CTranslate2 Provider Configuration
# =============================================================================
# Both faster_whisper (transcription) and nllb_ctranslate2 (translation)
# support these options, configurable per-tenant via the /configure API.
#
# compute_type options: int8 (default on CPU), float16 (default on CUDA), float32
# Higher precision = better accuracy, lower precision = lower memory + faster inference
# CT2_COMPUTE_TYPE=int8
#
# NLLB model cache: CTranslate2-converted models are cached at:
# ~/.cache/ctranslate2/<model_id>_<compute_type>/
# This conversion runs once automatically on first startup.

# =============================================================================
# Audio grabber client
# =============================================================================
# TRANSCRIBE_SERVER_URL=http://localhost:5040/transcripts
