+}
+
+
+.secondary-btn {
+    background-color: transparent;
+    border: 1.5px solid #d8e3f5;
+    color: #5a6a8a;
+    padding: 6px 10px;
+    border-radius: 8px;
+    cursor: pointer;
+    font-size: 0.85rem;
+    font-weight: 600;
+    font-family: 'Inter', Arial, sans-serif;
+    transition: all 0.15s;
+    text-decoration: none;
+    white-space: nowrap;
+}
+
+.secondary-btn:hover {
+    background-color: #f0f5ff;
+    border-color: #b8ccf0;
+    color: #4f8ef7;
+}
+
+/* Toggle Switch Styles */
+.audio-toggle-wrapper {
+    display: flex;
+    align-items: center;
+    gap: 8px;
+    background-color: #ffffff;
+    border: 1.5px solid #d8e3f5;
+    padding: 4px 10px;
+    border-radius: 8px;
+}
+
+#audio-toggle-label {
+    font-size: 0.85rem;
+    font-weight: 600;
+    color: #5a6a8a;
+    font-family: 'Inter', Arial, sans-serif;
+    min-width: 85px;
+}
+
+.switch {
+    position: relative;
+    display: inline-block;
+    width: 36px;
+    height: 20px;
+}
+
+.switch input { 
+    opacity: 0;
+    width: 0;
+    height: 0;
+}
+
+.slider {
+    position: absolute;
+    cursor: pointer;
+    top: 0;
+    left: 0;
+    right: 0;
+    bottom: 0;
+    background-color: #cbd5e1;
+    transition: .3s;
+}
+
+.slider:before {
+    position: absolute;
+    content: "";
+    height: 14px;
+    width: 14px;
+    left: 3px;
+    bottom: 3px;
+    background-color: white;
+    transition: .3s;
+}
+
+input:checked + .slider {
+    background-color: #16a34a;
+}
+
+input:checked + .slider:before {
+    transform: translateX(16px);
+}
+
+.slider.round {
+    border-radius: 34px;
+}
+
+.slider.round:before {
+    border-radius: 50%;
+}
+
+.captions-box {
+    width: 100%;
+    padding: 20px;
+    flex: 1;
+    min-height: 0;
+    overflow-y: auto;
+    font-family: 'Inter', Arial, sans-serif;
+    font-size: 1.05rem;
+    line-height: 1.6;
+    box-sizing: border-box;
+}
+
+/* Mobile: stack video on top, captions below with fixed height */
+@media (max-width: 900px) {
+    .stream-page {
+        height: auto;
+        overflow: auto;
+    }
+    .stream-container {
+        flex-direction: column;
+    }
+    .video-wrapper {
+        flex: none;
+        aspect-ratio: 16 / 9;
+        width: 100%;
+    }
+    .captions-wrapper {
+        flex: none;
+        height: 380px;
+    }
+}
+
+.system-msg {
+    color: #5a6a8a;
+    font-style: italic;
+    text-align: center;
+    margin-top: 40px;
+    font-size: 0.95rem;
+}
+
+/* Individual caption blocks */
+.caption-block {
+    margin-bottom: 14px;
+    padding-bottom: 14px;
+    border-bottom: 1px solid #e8f0fe;
+    animation: fadeIn 0.3s ease-out;
+}
+
+.caption-block:last-child {
+    border-bottom: none;
+    margin-bottom: 0;
+    padding-bottom: 0;
+}
+
+.transcript-text {
+    color: #5a6a8a; 
+    margin: 0 0 6px 0;
+    font-size: 0.95rem;
+}
+
+.translation-text {
+    color: #1a2340; 
+    font-weight: 600;
+    margin: 0;
+    font-size: 1.05rem;
+}
+
+/* Scrollbar styling for captions box */
+.captions-box::-webkit-scrollbar {
+    width: 8px;
+}
+.captions-box::-webkit-scrollbar-track {
+    background: #f8faff; 
+}
+.captions-box::-webkit-scrollbar-thumb {
+    background: #cddbfa; 
+    border-radius: 4px;
+}
+.captions-box::-webkit-scrollbar-thumb:hover {
+    background: #a9c1f7; 
+}
+
+/* Entry Animation */
+@keyframes fadeIn {
+    from { opacity: 0; transform: translateY(8px); }
+    to { opacity: 1; transform: translateY(0); }
+}
+
+/* Web Microphone Visualizer */
+#mic-container {
+    justify-content: center;
+    align-items: center;
+    width: 100%;
+    height: 100%;
+    background: #f8faff;
