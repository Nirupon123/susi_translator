+/* =====================================================
+   STREAM PAGE LAYOUT
+   The entire page is a fixed-height layout so neither 
+   the video nor captions can ever push the page down.
+   ===================================================== */
+
+/* Remove global main padding only on stream page */
+main:has(.stream-page) {
+    padding: 0 !important;
+    min-height: unset !important;
+}
+
+.stream-page {
+    display: flex;
+    flex-direction: column;
+    padding: 16px 20px;
+    box-sizing: border-box;
+    gap: 12px;
+    /* Fill exactly the viewport below the 60px navbar */
+    height: calc(100vh - 60px);
+    overflow: hidden;
+    background: #f8faff;
+}
+
+/* Side-by-side row: video on left, captions on right.
+   flex: 1 + min-height: 0 means this row fills the remaining
+   height without pushing the page down */
+.stream-container {
+    flex: 1;
+    min-height: 0;
+    display: flex;
+    flex-direction: row;
+    gap: 20px;
+    overflow: hidden;
+}
+
+
+/* Header area */
+.stream-header {
+    flex: none;
+    display: flex;
+    justify-content: space-between;
+    align-items: center;
+    margin-bottom: 8px;
+    padding-bottom: 16px;
+    border-bottom: 2px solid #e8f0fe;
+}
+
+.room-info h2 {
+    margin: 0 0 6px 0;
+    color: #1a2340;
+    font-size: 1.5rem;
+    font-weight: 700;
+    letter-spacing: -0.3px;
+}
+
+.tenant-badge {
+    background-color: #f0f5ff;
+    padding: 4px 12px;
+    border-radius: 6px;
+    font-size: 0.8rem;
+    font-family: monospace;
+    font-weight: 600;
+    color: #4f8ef7;
+    border: 1px solid rgba(79,142,247,0.2);
+}
+
+/* Status Indicator */
+.status-indicator {
+    display: flex;
+    align-items: center;
+    gap: 10px;
+    background: #ffffff;
+    padding: 8px 18px;
+    border-radius: 99px;
+    border: 1.5px solid #d8e3f5;
+    font-size: 0.9rem;
+    font-weight: 600;
+    color: #1a2340;
+    box-shadow: 0 2px 8px rgba(79,142,247,0.08);
+}
+
+.pulse-dot {
+    width: 10px;
+    height: 10px;
+    background-color: #f59e0b; /* Yellow for connecting */
+    border-radius: 50%;
+}
+
+.pulse-dot.connected {
+    background-color: #16a34a; /* Green for connected */
+    box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.2);
+}
+
+.pulse-dot.error {
+    background-color: #dc2626; /* Red for error */
+}
+
+/* Left Column: Video Player */
+.video-wrapper {
+    flex: 6;
+    min-width: 0;
+    background-color: #f8faff;
+    border-radius: 12px;
+    overflow: hidden;
+    border: 1.5px solid #d8e3f5;
+    box-shadow: 0 12px 32px rgba(79,142,247,0.12);
+    display: flex;
+    align-items: center;
+    justify-content: center;
+}
+
+#yt-player,
+#mic-container {
+    width: 100%;
+    height: 100%;
+    border: none;
+}
+
+/* Right Column: Live Captions */
+.captions-wrapper {
+    flex: 3.5;
+    min-width: 0;
+    background-color: #ffffff;
+    border: 1.5px solid #d8e3f5;
+    border-radius: 12px;
+    overflow: hidden;
+    display: flex;
+    flex-direction: column;
+    box-shadow: 0 12px 32px rgba(79,142,247,0.08);
+    min-height: 0;
+}
+
+.captions-header {
+    display: flex;
+    flex-direction: column;
+    align-items: flex-start;
+    padding: 14px 20px;
+    background-color: #f8faff;
+    border-bottom: 1.5px solid #d8e3f5;
+    gap: 12px;
+}
+
+.captions-header h3 {
+    margin: 0;
+    font-size: 1.05rem;
+    font-weight: 700;
+    color: #1a2340;
+}
+
+.captions-controls {
+    display: flex;
+    align-items: center;
+    gap: 8px;
+    flex-wrap: wrap;
+}
+
+.lang-selector-group {
+    display: flex;
+    align-items: center;
+    gap: 8px;
+}
+
+.lang-selector-group label {
+    font-size: 0.82rem;
+    font-weight: 600;
+    color: #5a6a8a;
+    white-space: nowrap;
+}
+
+.lang-selector-group select {
+    font-family: 'Inter', Arial, sans-serif;
