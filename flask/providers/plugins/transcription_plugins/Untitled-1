+    overflow: hidden;
+}
+
+.mic-icon {
+    font-size: 80px;
+    z-index: 10;
+    background: #ffffff;
+    width: 150px;
+    height: 150px;
+    border-radius: 50%;
+    display: flex;
+    justify-content: center;
+    align-items: center;
